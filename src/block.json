    "align": {
      "type": "string",
      "default": "full"
    },
    "purposeType": {
      "type": "string",
      "default": "test"
    },
    "colors": {
      "type": "object",
      "default": {
        "color": "black",
        "bg": "#B1C5A4"
      }
    }
  },
  "supports": {
    "align": ["wide", "full"],
    "html": false
  },
  "example": {
    "attributes": {}
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./view.css",
  "render": "file:./render.php",
  "viewScript": "file:./view.js"
}
