{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "b-blocks/test-purpose",
  "version": "1.0.0",
  "title": "Orbit Team",
  "category": "widgets",
  "description": "Orbit team is a block that will display your team members in a beautiful grid layout.",
  "keywords": ["Orbit Team"],
  "textdomain": "b-blocks",
  "attributes": {
    "alignment": {
      "type": "string",
      "default": "center"
